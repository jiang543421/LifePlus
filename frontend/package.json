{
  "name": "lifepulse-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:type": "vue-tsc --noEmit -p tsconfig.json",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "verify": "pnpm test && pnpm lint:type"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^11.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "element-plus": "^2.8.0",
    "pinia": "^2.2.0",
    "vue": "^3.4.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.0",
    "axios-mock-adapter": "^2.1.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
