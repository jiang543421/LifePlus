# LifePulse — 本地开发环境变量示例
# 复制为 .env 后按需修改；真实 .env 已在 .gitignore 中忽略。

# ====== Backend（Spring Boot 启动占位） ======
# MySQL JDBC URL。docker compose 默认 host=db；本地直连用 localhost
LP_DB_URL=jdbc:mysql://localhost:3306/lifepulse?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
LP_DB_USER=lp
LP_DB_PASS=lp_dev_only

# Redis。docker compose 默认 redis://redis:6379
LP_REDIS_URL=redis://localhost:6379

# JWT HS256 密钥。生产必须 ≥ 32 字节随机串；本地 dev 用 placeholder 即可
LP_JWT_SECRET=dev-only-secret-replace-me-32bytes-xxx

# CORS 白名单（issue R-004）。prod 必须显式覆盖；逗号分隔；禁 `*`、禁空
LP_CORS_ORIGINS=http://localhost

# AI daily provider 开关（spec ai-v2 §7.1）。v2.0 默认 false（stub），v2.1+ 设为 true
# 启用前需确保 v1.2.3 日报数据完整（避免 SQL 错误）
LP_AI_DAILY_ENABLED=false

# ====== Frontend（nginx 阶段 ARG） ======
# CSP connect-src 注入值。prod 必填；与后端 origin 一致
LP_API_ORIGIN=http://localhost:8080

# ====== docker-compose 一致性变量（与 docker-compose.yml 镜像） ======
# 改动这里不会自动同步进 compose；要改 compose 内置密码直接编辑 docker-compose.yml
MYSQL_DATABASE=lifepulse
MYSQL_USER=lp
MYSQL_PASSWORD=lp_dev_only
MYSQL_ROOT_PASSWORD=lp_root_only

# ====== LLM (v2.1) ======
# CLAUDE.md §11.2: deepseek 模式 api-key 必填且不能以 sk-replace- 开头
# 设置 LP_LLM_ENABLED=false 可完全禁用 LLM 增强，回退到 v2.0 模板引擎
LP_LLM_ENABLED=false
LP_LLM_PROVIDER=deepseek
LP_LLM_BASE_URL=https://api.deepseek.com/v1
LP_LLM_API_KEY=
LP_LLM_MODEL=deepseek-chat
LP_LLM_TIMEOUT_MS=5000
LP_LLM_MAX_PROMPT_TOKENS=1500
LP_LLM_MAX_RESPONSE_TOKENS=300
LP_LLM_DAILY_QUOTA=50
LP_LLM_CB_ENABLED=true
LP_LLM_CB_THRESHOLD=10
LP_LLM_CB_WINDOW=5
LP_LLM_CB_COOLDOWN=30

# === Optional: switch to local Ollama (deepseek-r1:8b) ===
# Start ollama service: docker compose --profile llm-ollama up -d
# Pull model (one-time):  docker compose exec ollama ollama pull deepseek-r1:8b
# LP_LLM_PROVIDER=ollama
# LP_LLM_BASE_URL=http://ollama:11434
# LP_LLM_MODEL=deepseek-r1:8b
