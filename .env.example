# LifePulse — 本地开发环境变量示例
# 复制为 .env 后按需修改；真实 .env 已在 .gitignore 中忽略。

# ====== Backend（Spring Boot 启动占位） ======
# MySQL JDBC URL。docker compose 默认 host=db；本地直连用 localhost
LP_DB_URL=jdbc:mysql://localhost:3306/lifepulse?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
LP_DB_USER=lp
LP_DB_PASS=lp_dev_only

# Redis。docker compose 默认 redis://redis:6379
LP_REDIS_URL=redis://localhost:6379

# JWT HS256 密钥。生产必须 ≥ 32 字节随机串；本地 dev 用 placeholder 即可
LP_JWT_SECRET=dev-only-secret-replace-me-32bytes-xxx

# ====== docker-compose 一致性变量（与 docker-compose.yml 镜像） ======
# 改动这里不会自动同步进 compose；要改 compose 内置密码直接编辑 docker-compose.yml
MYSQL_DATABASE=lifepulse
MYSQL_USER=lp
MYSQL_PASSWORD=lp_dev_only
MYSQL_ROOT_PASSWORD=lp_root_only
